{
    "name": "blissjaspis/laravel-query-detector",
    "description": "Laravel N+1 Query Detector",
    "keywords": [
        "blissjaspis",
        "laravel-query-detector"
    ],
    "homepage": "https://github.com/blissjaspis/laravel-query-detector",
    "license": "MIT",
    "authors": [
        {
            "name": "Bliss Jaspis",
            "email": "bliss@jaspis.me",
            "homepage": "https://bliss.jaspis.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "fruitcake/laravel-debugbar": "^4.1",
        "itsgoingd/clockwork": "^5.2",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0|^12.0|^13.0"
    },
    "suggest": {
        "fruitcake/laravel-debugbar": "Required to use the Debugbar output (^4.1).",
        "itsgoingd/clockwork": "Required to use the Clockwork output (^5.2)."
    },
    "autoload": {
        "psr-4": {
            "BlissJaspis\\QueryDetector\\": "src",
            "Workbench\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlissJaspis\\QueryDetector\\Tests\\": "tests",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "test": "vendor/bin/testbench package:test",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve"
        ],
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": [
            "@format:test",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlissJaspis\\QueryDetector\\QueryDetectorServiceProvider"
            ],
            "aliases": {
                "Querydetector": "BlissJaspis\\QueryDetector\\QueryDetector"
            }
        }
    }
}
